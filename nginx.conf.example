# nginx.conf — Konfigurasi Cache untuk koinshop.id (VPS Nginx + Static Export)
# Paste section ini ke dalam blok `server {}` atau `location` yang sesuai

server {
    listen 443 ssl;
    server_name koinshop.id www.koinshop.id;

    root /var/www/koinshop.id/out; # Path ke folder `out` hasil `next build`
    index index.html;

    # ─── Gzip Compression ───────────────────────────────────────────────
    gzip on;
    gzip_types text/plain text/css application/json application/javascript
               text/xml application/xml application/xml+rss text/javascript
               image/svg+xml font/woff2;
    gzip_min_length 1024;
    gzip_vary on;
    gzip_proxied any;
    gzip_comp_level 6;

    # ─── Cache: Next.js Static Assets (content-hashed, 1 tahun) ─────────
    # Aman untuk immutable karena nama file mengandung hash unik
    location /_next/static/ {
        add_header Cache-Control "public, max-age=31536000, immutable";
        add_header X-Content-Type-Options nosniff;
        try_files $uri =404;
    }

    # ─── Cache: Gambar Carousel (24 jam) ─────────────────────────────────
    location /carousel/ {
        add_header Cache-Control "public, max-age=86400, must-revalidate";
        try_files $uri =404;
    }

    # ─── Cache: Font Files (1 tahun, immutable) ──────────────────────────
    location ~* \.(woff2?|ttf|eot|otf)$ {
        add_header Cache-Control "public, max-age=31536000, immutable";
        add_header Access-Control-Allow-Origin "*";
        try_files $uri =404;
    }

    # ─── Cache: Images di Public root (7 hari) ───────────────────────────
    location ~* \.(webp|png|jpg|jpeg|gif|svg|ico)$ {
        add_header Cache-Control "public, max-age=604800, must-revalidate";
        try_files $uri =404;
    }

    # ─── Cache: CSS dan JS non-hashed (1 jam) ────────────────────────────
    location ~* \.(css|js)$ {
        add_header Cache-Control "public, max-age=3600, must-revalidate";
        try_files $uri =404;
    }

    # ─── Security Headers ────────────────────────────────────────────────
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    # ─── SPA Routing untuk Next.js Static Export ─────────────────────────
    location / {
        try_files $uri $uri/ $uri.html /index.html;
    }

    # ssl_certificate dan ssl_certificate_key dikonfigurasi sesuai setup Anda
    # ssl_certificate /etc/letsencrypt/live/koinshop.id/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/koinshop.id/privkey.pem;
}

# Redirect HTTP ke HTTPS
server {
    listen 80;
    server_name koinshop.id www.koinshop.id;
    return 301 https://$host$request_uri;
}
